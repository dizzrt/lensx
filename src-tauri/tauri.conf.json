{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "lensX",
  "version": "0.1.0",
  "identifier": "com.tauri.dev",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "windows": [
      {
        "title": "lensX",
        "width": 800,
        "height": 60,
        "decorations": false,
        "transparent": false,
        "resizable": false,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/lensx_cutout_2048.png"]
  }
}
