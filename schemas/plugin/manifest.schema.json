{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lensx.local/schemas/plugin/manifest.schema.json",
  "title": "lensX Plugin Manifest",
  "type": "object",
  "required": ["id", "name", "version", "source", "lifecycle", "runtime", "pages", "actions", "permissions"],
  "additionalProperties": false,
  "properties": {
    "id": { "$ref": "#/$defs/lensx_id" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "source": { "enum": ["builtin", "external"] },
    "lifecycle": {
      "type": "object",
      "required": ["uninstallable", "disableable"],
      "additionalProperties": false,
      "properties": {
        "uninstallable": { "type": "boolean" },
        "disableable": { "type": "boolean" }
      }
    },
    "runtime": {
      "oneOf": [
        {
          "type": "object",
          "required": ["ui", "module"],
          "additionalProperties": false,
          "properties": {
            "ui": { "const": "vue_module" },
            "module": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "required": ["ui", "entry"],
          "additionalProperties": false,
          "properties": {
            "ui": { "const": "iframe" },
            "entry": { "type": "string", "minLength": 1 },
            "sandbox": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      ]
    },
    "pages": {
      "type": "array",
      "items": { "$ref": "#/$defs/page" }
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },
    "permissions": {
      "type": "array",
      "items": { "$ref": "#/$defs/permission" }
    },
    "sdk": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_version": { "type": "string" }
      }
    },
    "host_api": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_version": { "type": "string" }
      }
    },
    "sidecar": {
      "type": "object",
      "required": ["enabled"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "command": { "type": "string" },
        "args": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "lensx_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*\\.[a-z][a-z0-9_-]*\\.[a-z][a-z0-9_-]*$"
    },
    "permission_ref_list": {
      "type": "array",
      "items": { "$ref": "#/$defs/lensx_id" }
    },
    "page": {
      "type": "object",
      "required": ["id", "plugin_id", "title", "entry"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/lensx_id" },
        "plugin_id": { "$ref": "#/$defs/lensx_id" },
        "title": { "type": "string", "minLength": 1 },
        "entry": { "type": "string", "minLength": 1 },
        "parent_page_id": { "$ref": "#/$defs/lensx_id" },
        "required_permissions": { "$ref": "#/$defs/permission_ref_list" }
      }
    },
    "action": {
      "type": "object",
      "required": ["id", "plugin_id", "title", "target_page_id"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/lensx_id" },
        "plugin_id": { "$ref": "#/$defs/lensx_id" },
        "title": { "type": "string", "minLength": 1 },
        "target_page_id": { "$ref": "#/$defs/lensx_id" },
        "required_permissions": { "$ref": "#/$defs/permission_ref_list" }
      }
    },
    "permission": {
      "type": "object",
      "required": ["id", "plugin_id", "title"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/lensx_id" },
        "plugin_id": { "$ref": "#/$defs/lensx_id" },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    }
  }
}
